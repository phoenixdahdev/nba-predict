# Database (Neon Postgres via Vercel Marketplace)
DATABASE_URL=

# Redis (Upstash via Vercel Marketplace — use redis:// URL, not REST URL)
REDIS_URL=

# Telegram Bot (from BotFather)
TELEGRAM_BOT_TOKEN=

# balldontlie API (from https://app.balldontlie.io)
BALLDONTLIE_API_KEY=

# Trigger.dev (from dashboard)
TRIGGER_SECRET_KEY=

# Google AI (from Google AI Studio or via Vercel AI Gateway OIDC)
GOOGLE_GENERATIVE_AI_API_KEY=

# Port (optional, defaults to 3000)
PORT=3000
