{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "bunVersion": "1",
  "buildCommand": "bun install",
  "installCommand": "bun install",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ]
}
